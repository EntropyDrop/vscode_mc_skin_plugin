{
  "name": "vscode-mc-skin-preview",
  "displayName": "Minecraft Skin 3D Previewer",
  "description": "Preview Minecraft PNG skins in interactive 3D using mc_skin_utils",
  "version": "0.1.0",
  "publisher": "entropydrop",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mc-skin-preview.preview",
        "title": "Preview Minecraft Skin (3D)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .png",
          "command": "mc-skin-preview.preview",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "when": "resourceExtname == .png",
          "command": "mc-skin-preview.preview",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceExtname == .png",
          "command": "mc-skin-preview.preview",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Minecraft Skin Previewer",
      "properties": {
        "mcSkinPreview.previewCommand": {
          "type": "string",
          "default": "mc_preview",
          "description": "The command or absolute path to the mc_preview executable."
        },
        "mcSkinPreview.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Optional: Path to the python interpreter if running mc_preview module directly."
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0"
  }
}
